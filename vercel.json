{
  "buildCommand": "pnpm build && node scripts/deploy-build.mjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/api/(.*)$", "dest": "/api/[...route]?...route=$1" },
    { "handle": "error" },
    { "status": 404, "src": "^(?!/api).*$", "dest": "/404.html" },
    { "handle": "miss" },
    { "src": "^/api/(.+)(?:\\.(?:js))$", "dest": "/api/$1", "check": true }
  ]
}
