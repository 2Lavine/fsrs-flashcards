{
  "name": "fsrs-flashcards",
  "private": true,
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:client": "pnpm --filter @fsrs/client dev",
    "dev:server": "pnpm --filter @fsrs/server dev",
    "build": "pnpm --filter @fsrs/client build && node scripts/build-api.mjs",
    "build:api": "node scripts/build-api.mjs",
    "deploy": "pnpm build && vercel deploy --prod",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@vercel/node": "^5.8.15",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.2.0",
    "@libsql/client": "^0.17.3",
    "ai": "^4.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "ts-fsrs": "^5.4.1"
  }
}
