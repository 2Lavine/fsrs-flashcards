#!/bin/sh
# Pre-push hook: deploy to Vercel when pushing to main

current_branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$current_branch" = "main" ]; then
  echo ""
  echo "→ Pushing to main. Deploying to Vercel..."
  echo ""
  if pnpm deploy; then
    echo ""
    echo "✓ Deployed successfully"
    echo ""
  else
    echo ""
    echo "✗ Deploy failed. Push aborted."
    exit 1
  fi
fi
